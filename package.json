{
  "name": "item-piles-symbaroum",
  "version": "1.1.0",
  "description": "Integração comunitária do Item Piles com Symbaroum para Foundry VTT.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kciquehn/item-piles-symbaroum.git"
  },
  "homepage": "https://github.com/Kciquehn/item-piles-symbaroum#readme",
  "bugs": {
    "url": "https://github.com/Kciquehn/item-piles-symbaroum/issues"
  },
  "author": "Kciquehn (https://github.com/Kciquehn)",
  "contributors": [
    "Wasp <adam@fantasy-calendar.com> (https://github.com/haxxer)",
    "Fantasy Computerworks (https://github.com/fantasycalendar)"
  ],
  "imports": {
    "#runtime/*": "@typhonjs-fvtt/runtime/*",
    "#standard/*": "@typhonjs-fvtt/standard/*"
  },
  "dependencies": {
    "@typhonjs-fvtt/runtime": "^0.2.0",
    "@typhonjs-fvtt/standard": "^0.2.0",
    "svelte": "^4.0.0",
    "svelte-select": "^5.7.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "classic-level": "^3.0.0",
    "svelte-dnd-action": "^0.9.18",
    "svelte-preprocess": "^6.0.0",
    "vite": "^8.1.5"
  },
  "browserslist": [
    ">5%",
    "not IE 11"
  ],
  "scripts": {
    "audit:symbaroum-items": "node tools/audit-symbaroum-module-items.mjs",
    "generate:symbaroum-categories": "node tools/generate-symbaroum-module-categories.mjs",
    "refresh:symbaroum-categories": "npm run audit:symbaroum-items && npm run generate:symbaroum-categories",
    "generate:services": "node tools/generate-symbaroum-services-pack.mjs",
    "prebuild": "node tools/patch-typhonjs-keyboard-manager.mjs",
    "build": "vite build",
    "dev": "vite",
    "validate:release": "node tools/validate-release.mjs"
  }
}
